              "mode": "raw",
              "raw": "{\n  \"nombreCompleto\": \"Juan Pérez García\",\n  \"correo\": \"juan.perez@swo.com\",\n  \"password\": \"Segura@2024\",\n  \"rol\": \"Técnico\",\n  \"telefono\": \"3001234567\",\n  \"departamento\": \"Sistemas\",\n  \"idJefe\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/usuarios", "host": ["{{baseUrl}}"], "path": ["usuarios"] },
            "description": "Crea un nuevo usuario. El password se almacena hasheado con BCrypt.\n\nRoles válidos:\n- Soporte, Jefe, Usuario, Administrador, Técnico, Analista\n- Desarrollador, Mesa de Servicio, Consultor, Auditor\n- Coordinador, Gerente, QA"
          }
        },
        {
          "name": "Actualizar usuario",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreCompleto\": \"Juan Pérez García\",\n  \"correo\": \"juan.perez@swo.com\",\n  \"rol\": \"Analista\",\n  \"telefono\": \"3009876543\",\n  \"departamento\": \"TI\",\n  \"idJefe\": 1\n}",
              "options": { "raw": { "language": "json" } }
