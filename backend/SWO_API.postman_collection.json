{
  "info": {
    "name": "SWO API - Sistema de Gestión de Incidencias",
    "description": "Colección completa de endpoints REST para la API SWO (Spring Boot 3 + MySQL).\n\nBase URL: {{baseUrl}}/api\n\nVariables de entorno requeridas:\n- baseUrl: URL de Railway (ej: https://swo-api.up.railway.app) o http://localhost:8081 en local",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "description": "Cambiar a la URL de Railway al desplegar"
    }
  ],
  "item": [
    {
      "name": "🔐 Autenticación",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@swo.com\",\n  \"password\": \"Admin1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "login"]
            },
            "description": "Autentica al usuario con correo y contraseña. Retorna datos del usuario si las credenciales son correctas."
          }
        }
      ]
    },
