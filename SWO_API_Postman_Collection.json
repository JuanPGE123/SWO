          }
        },
        {
          "name": "Cambiar contraseña",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nuevaPassword\": \"NuevaClave@2025\"\n}",
              "options": { "raw": { "language": "json" } }
