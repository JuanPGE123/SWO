          }
        },
        {
          "name": "Desactivar usuario (soft delete)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios/{{userId}}/desactivar",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "{{userId}}", "desactivar"]
            },
            "description": "Desactiva el usuario (estado = false). No elimina el registro."
          }
        },
        {
          "name": "Activar usuario",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios/{{userId}}/activar",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "{{userId}}", "activar"]
            },
            "description": "Reactiva un usuario previamente desactivado."
          }
        },
        {
          "name": "Eliminar usuario (permanente)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "{{userId}}"]
            },
            "description": "⚠️ Eliminación permanente. Usar con precaución."
          }
        }
      ]
    },
