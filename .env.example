# ════════════════════════════════════════════════════════════════════════════
# ARCHIVO .env - VARIABLES DE ENTORNO PARA SWO
# ════════════════════════════════════════════════════════════════════════════
#
# IMPORTANTE: 
# - Copiar este archivo como .env en la raíz del proyecto
# - Nunca commitear .env (está en .gitignore)
# - Usar .env.local para desarrollo local
# - Usar .env.test para ambiente de testing
# - Usar .env.prod para producción (secretos en CI/CD)
#
# ════════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────────
# AMBIENTE
# ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev

# ────────────────────────────────────────────────────────────────────────
# FRONTEND - ANGULAR
# ────────────────────────────────────────────────────────────────────────
NG_APP_API_URL=http://localhost:8080/api
NG_APP_ENV=development
NG_APP_LOG_LEVEL=DEBUG
NG_APP_TIMEOUT=30000

# ────────────────────────────────────────────────────────────────────────
# BACKEND - SPRING BOOT
# ────────────────────────────────────────────────────────────────────────
SPRING_APPLICATION_NAME=swo-api
SPRING_SERVER_PORT=8080
SPRING_SERVER_SERVLET_CONTEXT_PATH=/api

# ────────────────────────────────────────────────────────────────────────
# BASE DE DATOS
# ────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=swo_dev
DB_USER=root
DB_PASSWORD=root
DB_DRIVER=com.mysql.cj.jdbc.Driver

# JDBC URL completa (alternativa)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/swo_dev?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# ────────────────────────────────────────────────────────────────────────
# DOCKER & DOCKER-COMPOSE
# ────────────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpassword123
DB_PROD_USER=swo_prod
DB_PROD_PASSWORD=swo_prod_password456

# ────────────────────────────────────────────────────────────────────────
# AUTENTICACIÓN & SEGURIDAD
# ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=tu_clave_secreta_muy_larga_y_segura_aqui_cambiar_en_produccion
JWT_EXPIRATION_TIME=86400000
JWT_REFRESH_EXPIRATION_TIME=604800000

# ────────────────────────────────────────────────────────────────────────
# TESTING
# ────────────────────────────────────────────────────────────────────────
TEST_USER_EMAIL=test@swo.local
TEST_USER_PASSWORD=Test123456!
COVERAGE_THRESHOLD=80

# ────────────────────────────────────────────────────────────────────────
# CYPRESS (E2E Testing)
# ────────────────────────────────────────────────────────────────────────
CYPRESS_BASE_URL=http://localhost:4200
CYPRESS_API_URL=http://localhost:8080/api
CYPRESS_HEADLESS=false

# ────────────────────────────────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────────────────────────────────
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SWO=DEBUG

# ────────────────────────────────────────────────────────────────────────
# PARÁMETROS JVM (Java)
# ────────────────────────────────────────────────────────────────────────
JAVA_OPTS=-Xmx512m -Xms256m -XX:+UseG1GC

# ════════════════════════════════════════════════════════════════════════════
# CONFIGURACIONES POR AMBIENTE
# ════════════════════════════════════════════════════════════════════════════

# DESARROLLO (.env.dev)
# Todos los valores por defecto (arriba) son para desarrollo

# TESTING (.env.test)
# - Cambiar a base de datos en memoria (H2)
# - Cambiar NODE_ENV=test
# - Cambiar SPRING_PROFILES_ACTIVE=test

# PRODUCCIÓN (.env.prod)
# - Cambiar a hostname real de BD
# - Cambiar JWT_SECRET_KEY a valor seguro
# - Cambiar LOGGING_LEVEL_ROOT=WARN
# - Cambiar CYPRESS_HEADLESS=true (si se usa)
# - Cambiar NODE_ENV=production
